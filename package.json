{
  "name": "@pavy/marketing-repo",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "dev:site": "turbo dev --filter @pavy/site",
    "dev:deck": "turbo dev --filter @pavy/sales-deck",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.4.4"
  }
}
