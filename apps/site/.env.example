# GA4 Measurement ID (e.g., G-XXXXXXXXXX)
VITE_GA4_MEASUREMENT_ID=

# Admin signup URL — point CTA buttons at the admin app's signup page.
# Admin Vite is configured with `base: '/admin/'`, so /admin/ is part of the path.
# Dev: http://localhost:3000/admin/signup
# Prod: depends on how the admin app is deployed. If the subdomain serves the
#       admin app at the root, set https://admin.pavy.ai/signup. If the prod
#       build keeps the /admin/ base path, set https://admin.pavy.ai/admin/signup.
VITE_ADMIN_SIGNUP_URL=http://localhost:3000/admin/signup
