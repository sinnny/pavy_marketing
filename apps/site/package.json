{
  "name": "@pavy/site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run generate-sitemap && npm run generate-rss && vite build",
    "analyze": "ANALYZE=true npm run build",
    "generate-sitemap": "node --experimental-strip-types scripts/generate-sitemap.ts",
    "generate-rss": "node --experimental-strip-types scripts/generate-rss.ts",
    "generate-webp": "node --experimental-strip-types scripts/generate-webp.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@pavy/i18n": "workspace:*",
    "@pavy/types": "workspace:*",
    "@pavy/ui": "workspace:*",
    "@pavy/utils": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.0",
    "framer-motion": "^12.0.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.474.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.1.5",
    "rehype-highlight": "^7.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@pavy/tailwind-config": "workspace:*",
    "@pavy/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^2.0.3"
  }
