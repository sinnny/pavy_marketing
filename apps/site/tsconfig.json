{
  "extends": "@pavy/tsconfig/react",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../../packages/types"
    },
    {
      "path": "../../packages/constants"
    },
    {
      "path": "../../packages/utils"
    },
    {
      "path": "../../packages/ui"
    },
    {
      "path": "../../packages/i18n"
    }
  ]
}
